__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local run products. Wrappers write here by default.
runs/
outputs/
run_*/
reference_outputs/
site/
*.log

# Local smoke-test packets and copied HPC sandboxes.
tests/

# User-supplied data. Keep GitHub scripts-only.
/data/

# Generated workflow data and heavy simulation products.
/workflows/**/outputs/
/workflows/**/data/derived/*
!/workflows/**/data/derived/.gitkeep
/workflows/**/*.png
/workflows/**/*.pdf
/workflows/**/*.jpg
/workflows/**/*.jpeg
/workflows/**/*.svg
/workflows/**/*.nc
/workflows/**/*.dcd
/workflows/**/*.xtc
/workflows/**/*.trr
/workflows/**/*.agr
/workflows/**/*.tsv

# OS/editor noise.
.DS_Store
desktop.ini

# Local maintainer/agent notes, not public docs.
/CHECKPOINT.md
/docs/CHECKPOINT.md
/docs/private_notes/
.local_notes/
.local_docs/
mkdocs.local.yml

# Runtime job state.
.last_hpc_job_id
.last_network_hpc_job_id
*.runtime.cxc
