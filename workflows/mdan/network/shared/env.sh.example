#!/usr/bin/env bash
# Copy or source this file, then edit paths for your machine/account.

export VARMDYN_CONDA_ENV="${VARMDYN_CONDA_ENV:-varmdyn_dynetan}"
export VARMDYN_DYNETAN_ENV="${VARMDYN_DYNETAN_ENV:-varmdyn_dynetan}"
export VARMDYN_NCORES="${VARMDYN_NCORES:-8}"
export VARMDYN_DYNETAN_STAGE_TAG="${VARMDYN_DYNETAN_STAGE_TAG:-varmdyn_network_full}"
export NUMBA_CACHE_DIR="${NUMBA_CACHE_DIR:-$PWD/runs/numba_cache}"

# Local/HPC checkout roots.
export VARMDYN_REPO="${VARMDYN_REPO:-$PWD}"
export VARMDYN_HPC_HOST="${VARMDYN_HPC_HOST:-user@login.example.edu}"
export VARMDYN_HPC_REPO="${VARMDYN_HPC_REPO:-/path/to/hpc/network_shared}"
export VARMDYN_SSH_COMMAND="${VARMDYN_SSH_COMMAND:-ssh}"
export VARMDYN_RSYNC_SSH="${VARMDYN_RSYNC_SSH:-$VARMDYN_SSH_COMMAND}"

# Simulation roots. Set at least one before running array jobs.
export VARMDYN_APO_ROOT="${VARMDYN_APO_ROOT:-/path/to/apo/simulation/root}"
export VARMDYN_HOLO_ROOT="${VARMDYN_HOLO_ROOT:-/path/to/holo/simulation/root}"

# Optional subset. Leave unset to auto-discover all NN_NAME folders.
# export VARMDYN_VARIANTS=01_WT,02_L119R

# Output locations inside the checkout. These are ignored by git.
export VARMDYN_NETWORK_DATA_ROOT="${VARMDYN_NETWORK_DATA_ROOT:-$VARMDYN_REPO/data/network/full}"
export VARMDYN_NETWORK_RUN_ROOT="${VARMDYN_NETWORK_RUN_ROOT:-$VARMDYN_REPO/runs/mdan/network_full}"
